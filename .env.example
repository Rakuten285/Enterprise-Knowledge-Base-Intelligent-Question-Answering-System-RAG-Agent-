# ============================================================
# 企业知识库智能问答系统 - 环境变量配置示例
# 复制为 .env 后填入真实密钥；.env 已在 .gitignore 中忽略
# ============================================================

# ---------- LLM Provider ----------
# 支持: deepseek | zhipu | qwen | openai
LLM_PROVIDER=deepseek

# DeepSeek（默认，性价比高，注册有免费额度）
# 申请地址: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 智谱 GLM（可选）
# 申请地址: https://open.bigmodel.cn
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-flash

# 通义千问（可选）
# 申请地址: https://dashscope.console.aliyun.com
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# OpenAI（可选，国外）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ---------- Embedding Provider ----------
# 支持: bge_local | openai | zhipu
# bge_local: 完全免费、离线运行，无需任何 API Key（默认推荐）
EMBEDDING_PROVIDER=bge_local

# 本地 BGE 模型（自动从 HuggingFace 下载，约 400MB）
BGE_MODEL_NAME=BAAI/bge-small-zh-v1.5
BGE_DEVICE=cpu

# OpenAI Embedding（可选）
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# 智谱 Embedding（可选）
ZHIPU_EMBEDDING_MODEL=embedding-3

# ---------- 检索配置 ----------
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5
# 混合检索融合策略: rrf | weighted
HYBRID_FUSION_STRATEGY=rrf
VECTOR_WEIGHT=0.5
BM25_WEIGHT=0.5
RRF_K=60
# 是否启用 MMR 去重
MMR_ENABLED=true
MMR_LAMBDA=0.7
MMR_FETCH_K=20

# ---------- 向量库 ----------
VECTORSTORE_DIR=./data/vectorstore
VECTORSTORE_INDEX_NAME=kb_index

# ---------- Redis（会话缓存） ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ---------- LangSmith 链路追踪（可选） ----------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=enterprise-rag-agent

# ---------- 应用配置 ----------
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
